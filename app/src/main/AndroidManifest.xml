<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="Private Space Fix"
        android:allowBackup="false">

        <!--
            LSPosed / libxposed 必要宣告
            xposedminversion = 100 對應 libxposed api:100
        -->
        <meta-data
            android:name="xposedminversion"
            android:value="101" />

        <meta-data
            android:name="xposedmodule"
            android:value="true" />

        <meta-data
            android:name="xposeddescription"
            android:value="Fix Nothing Launcher: Private Space shows profile apps instead of hidden apps" />

        <!--
            作用域：僅注入 Nothing Launcher 程序。
            確認方式：adb shell pm list packages | grep nothing
        -->
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposed_scope" />

    </application>

</manifest>
